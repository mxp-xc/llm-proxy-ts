{
  "name": "llm-proxy",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts"
    }
  },
  "scripts": {
    "dev": "bun src/cli/cli.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "generate:schema": "tsx scripts/generate-schema.ts",
    "models:sync": "tsx src/cli/cli.ts models sync",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.81",
    "@ai-sdk/openai": "^3.0.71",
    "@ai-sdk/openai-compatible": "^2.0.50",
    "@clack/prompts": "^1.5.1",
    "@hono/node-server": "^2.0.4",
    "ai": "^6.0.197",
    "commander": "^15.0.0",
    "dotenv": "^17.4.2",
    "hono": "^4.12.25",
    "jsonc-parser": "^3.3.1",
    "pino": "^10.3.1",
    "undici": "^8.4.1",
    "zod": "^4.4.3",
    "zod-to-json-schema": "^3.24.5"
  },
  "devDependencies": {
    "@types/node": "latest",
    "prettier": "^3.8.3",
    "tsx": "latest",
    "typescript": "latest",
    "vitest": "latest"
  }
}

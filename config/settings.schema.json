{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "$schema": {
      "type": "string"
    },
    "service": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1,
          "default": "llm-proxy"
        },
        "host": {
          "type": "string",
          "minLength": 1,
          "default": "127.0.0.1"
        },
        "port": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535,
          "default": 8000
        }
      },
      "additionalProperties": false,
      "default": {}
    },
    "requestTimeoutMs": {
      "type": "number",
      "exclusiveMinimum": 0,
      "default": 30000
    },
    "proxy": {
      "anyOf": [
        {
          "type": "object",
          "properties": {
            "url": {
              "type": "string",
              "format": "uri"
            },
            "verify": {
              "type": "boolean",
              "default": true
            }
          },
          "required": [
            "url"
          ],
          "additionalProperties": false
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "routing": {
      "type": "object",
      "properties": {
        "enableFlatModelLookup": {
          "type": "boolean",
          "default": false
        }
      },
      "additionalProperties": false,
      "default": {}
    },
    "providers": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "const": "openai-compatible"
          },
          "baseURL": {
            "type": "string",
            "format": "uri"
          },
          "apiKey": {
            "anyOf": [
              {
                "anyOf": [
                  {
                    "type": "string",
                    "minLength": 1
                  },
                  {
                    "type": "array",
                    "items": {
                      "type": "string",
                      "minLength": 1
                    },
                    "minItems": 1
                  }
                ]
              },
              {
                "type": "null"
              }
            ]
          },
          "headers": {
            "type": "object",
            "additionalProperties": {
              "type": "string"
            },
            "default": {}
          },
          "plugins": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "name": {
                  "type": "string",
                  "minLength": 1
                },
                "config": {
                  "type": "object",
                  "additionalProperties": {},
                  "default": {}
                }
              },
              "required": [
                "name"
              ],
              "additionalProperties": false
            },
            "default": []
          },
          "models": {
            "type": "object",
            "additionalProperties": {
              "type": "object",
              "properties": {
                "upstreamModel": {
                  "type": "string",
                  "minLength": 1
                },
                "aliases": {
                  "type": "array",
                  "items": {
                    "type": "string",
                    "minLength": 1
                  },
                  "default": []
                },
                "headers": {
                  "type": "object",
                  "additionalProperties": {
                    "type": "string"
                  },
                  "default": {}
                },
                "plugins": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "name": {
                        "type": "string",
                        "minLength": 1
                      },
                      "config": {
                        "type": "object",
                        "additionalProperties": {},
                        "default": {}
                      }
                    },
                    "required": [
                      "name"
                    ],
                    "additionalProperties": false
                  },
                  "default": []
                }
              },
              "required": [
                "upstreamModel"
              ],
              "additionalProperties": false
            },
            "default": {}
          },
          "enableFlatModelLookup": {
            "type": "boolean"
          },
          "oauth": {
            "type": "object",
            "properties": {
              "flow": {
                "type": "string",
                "enum": [
                  "authorization_code",
                  "client_credentials"
                ]
              },
              "clientId": {
                "type": "string",
                "minLength": 1
              },
              "clientSecret": {
                "type": "string",
                "minLength": 1
              },
              "tokenUrl": {
                "type": "string",
                "format": "uri"
              },
              "authorizationUrl": {
                "type": "string",
                "format": "uri"
              },
              "scopes": {
                "type": "array",
                "items": {
                  "type": "string",
                  "minLength": 1
                },
                "default": []
              },
              "redirectUri": {
                "type": "string",
                "format": "uri"
              },
              "authFile": {
                "type": "string"
              }
            },
            "required": [
              "flow",
              "clientId",
              "clientSecret",
              "tokenUrl"
            ],
            "additionalProperties": false
          },
          "auth": {
            "type": "object",
            "properties": {
              "module": {
                "type": "string",
                "minLength": 1
              },
              "config": {
                "type": "object",
                "additionalProperties": {},
                "default": {}
              }
            },
            "required": [
              "module"
            ],
            "additionalProperties": false
          },
          "modelsEndpoint": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": [
          "type",
          "baseURL"
        ],
        "additionalProperties": false
      },
      "default": {}
    }
  },
  "additionalProperties": false,
  "title": "Settings"
}

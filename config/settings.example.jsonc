{
  "$schema": "./settings.schema.json",
  "service": {
    "name": "llm-proxy",
    "host": "127.0.0.1",
    "port": 8056,
  },
  "requestTimeoutMs": 30000,
  // To use an explicit proxy:
  // "proxy": { "url": "http://127.0.0.1:7890", "verify": true },
  "proxy": null,
  "routing": {
    "enableFlatModelLookup": true,
  },
  "plugins": [
    // Auth plugin example (custom token endpoint → Bearer header):
    // {
    //   "module": "./plugins/auth-demo/index.ts",
    //   "providers": "my-provider",
    //   "config": {
    //     "tokenUrl": "https://auth.example.com/oauth2/token",
    //     "clientId": "${MY_CLIENT_ID}",
    //     "clientSecret": "${MY_CLIENT_SECRET}"
    //   }
    // }
  ],
  "codex": {
    // Codex CLI catalog overrides (passthrough to codex bundled catalog):
    "models_catalog": {
      // Default context window when model.limit.context is not set.
      "context_window": 200000,
      // Template slug from codex bundled catalog (fallback: first supported_in_api entry).
      // "templateSlug": "gpt-5.4",
    },
    // Codex install config (bun dev codex install → ~/.codex/config.toml):
    "install": {
      // Provider id in [model_providers.<id>] table; also written as model_provider.
      // "providerId": "llm-proxy",
      // Display name in the provider table.
      // "providerName": "LLM Proxy",
      // Whether codex sends OpenAI auth headers to the proxy.
      "requiresOpenaiAuth": true,
      // Optional system prompt override offered by `codex install`; omit to preserve Codex config.
      // "systemPrompt": "gpt-5.6",
    },
  },
  "providers": {
    "local-openai": {
      "type": "openai-compatible",
      "baseURL": "http://example.com/v1",
      "apiKey": ["example-api-key", "${LOCAL_OPENAI_API_KEY_2}"],
      // "options": {
      //   // Custom models API endpoint (default: /models appended to baseURL).
      //   // Relative path: appended to baseURL.
      //   "modelsEndpoint": "/v1/models",
      //   // Full URL: used directly, ignoring baseURL.
      //   // "modelsEndpoint": "https://other.api.com/list",
      //   // Override the routing-level enableFlatModelLookup setting per-provider.
      //   // If omitted, inherits from routing.enableFlatModelLookup.
      //   // "enableFlatModelLookup": false,
      //   // Set includeUsage: false to disable stream_options (for upstream that doesn't support it).
      //   // "includeUsage": false,
      //   // Force all requests through streaming path (for providers that only support streaming).
      //   // "streamOnly": true,
      //   // Disable tools for every model under this provider. Strings match exactly;
      //   // explicit glob entries support * and ? with case-sensitive matching.
      //   // "disabled-tools": ["apply_patch", { "glob": "mcp__github__*" }],
      //   // Reasoning effort default for all models under this provider:
      //   // "reasoning_effort": { "default": "medium", "supported": ["low", "medium", "high"] },
      // },
      "plugins": ["vendor_sse_error"],
      "models": {
        "gpt-5.5": {
          "upstreamModel": "gpt-5.5",
          // Reasoning effort (model property, used by codex catalog + config.toml):
          // "reasoning_effort": {
          //   "default": "high",
          //   "supported": ["low", "medium", "high", "xhigh"],
          // },
          // Additional tools disabled only for this model:
          // "disabled-tools": ["web_search"],
        },
      },
    },
    // OAuth provider example (Authorization Code flow):
    // "oauth-provider": {
    //   "type": "openai-compatible",
    //   "baseURL": "https://api.example.com/v1",
    //   "oauth": {
    //     "flow": "authorization_code",
    //     "clientId": "${OAUTH_CLIENT_ID}",
    //     "clientSecret": "${OAUTH_CLIENT_SECRET}",
    //     "tokenUrl": "https://auth.example.com/oauth2/token",
    //     "authorizationUrl": "https://auth.example.com/oauth2/authorize",
    //     "scopes": ["api.read", "api.write"]
    //   },
    //   "models": { "chat": { "upstreamModel": "model-x" } }
    // },
    // OAuth provider example (Client Credentials flow):
    // "service-account": {
    //   "type": "openai-compatible",
    //   "baseURL": "https://api.example.com/v1",
    //   "oauth": {
    //     "flow": "client_credentials",
    //     "clientId": "${OAUTH_CLIENT_ID}",
    //     "clientSecret": "${OAUTH_CLIENT_SECRET}",
    //     "tokenUrl": "https://auth.example.com/oauth2/token",
    //     "scopes": ["api.read"]
    //   },
    //   "models": { "chat": { "upstreamModel": "model-y" } }
    // },
    // Provider using auth plugin (configured in global plugins above):
    // "my-provider": {
    //   "type": "openai-compatible",
    //   "baseURL": "https://api.example.com/v1",
    //   "models": { "chat": { "upstreamModel": "model-x" } }
    // },
    // Anthropic provider (native Messages API at /v1/messages):
    // "anthropic": {
    //   "type": "anthropic",
    //   "apiKey": "${ANTHROPIC_API_KEY}",
    //   // baseURL is optional — defaults to https://api.anthropic.com/v1
    //   // "baseURL": "https://api.anthropic.com/v1",
    //   // "options": {
    //   //   // Override the default anthropic-version header:
    //   //   "anthropicVersion": "2023-06-01",
    //   // },
    //   "models": {
    //     "sonnet": { "upstreamModel": "claude-sonnet-4-5" },
    //     "haiku": { "upstreamModel": "claude-haiku-4-5" },
    //   }
    // },
  },
}
